# Copy to .env and fill in as needed. Nothing here is required for `replay` mode.
# The contracts package never raises at import for a missing OPENAI_API_KEY;
# the planner worktree raises only when a live planner call is actually attempted.

OPENAI_API_KEY=
CTGOV_BASE_URL=https://clinicaltrials.gov/api/v2
CACHE_DIR=.cache
PLANNER_MODEL=gpt-4.1
DEFAULT_MODE=live
